<script>
function filterProducts(btn,cat){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.product-card').forEach(card=>{
    const brand=card.querySelector('.product-brand').textContent;
    card.classList.toggle('hidden',cat!=='all'&&brand!==cat);
  });
}
function editPrice(el){
  const current=el.textContent.replace('FCFA','').replace('✏️','').trim();
  const input=document.createElement('input');
  input.className='price-input';
  input.value=current;
  input.onblur=function(){el.innerHTML=this.value+' <span>FCFA ✏️</span>';el.onclick=function(){editPrice(this);};};
  input.onkeydown=function(e){if(e.key==='Enter')this.blur();};
  el.innerHTML='';el.appendChild(input);input.focus();input.select();
}
const obs=new IntersectionObserver((entries)=>{entries.forEach((e,i)=>{if(e.isIntersecting)setTimeout(()=>e.target.classList.add('visible'),i*70);});},{threshold:0.08});
document.querySelectorAll('.fade-up').forEach(el=>obs.observe(el));
window.addEventListener('scroll',()=>{document.getElementById('navbar').style.padding=window.scrollY>50?'10px 40px':'16px 40px';});
function sendWhatsApp(){
  const name=document.getElementById('f-name').value||'Client';
  const phone=document.getElementById('f-phone').value||'Non renseigné';
  const product=document.getElementById('f-product').value||'Non spécifié';
  const msg=document.getElementById('f-msg').value||'';
  const text='Bonjour MENDY FASHION ! \n\nCommande :\n Nom: '+name+'\n Tel: '+phone+'\n Article: '+product+'\n Message: '+msg;
  window.open('https://wa.me/221777454525?text='+encodeURIComponent(text),'_blank');
}
